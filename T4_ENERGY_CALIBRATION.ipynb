{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {"id": "title"},
   "source": [
    "# T4 Energy Calibration for ShadowKV++\n",
    "\n",
    "This notebook runs the energy measurement experiment on a **Google Colab T4 GPU**.\n",
    "\n",
    "**What it does:**\n",
    "1. Installs the ShadowKV++ codebase and dependencies\n",
    "2. Runs the energy calibration benchmark (36 cells, ~72 min, or 20 cells with `--quick`)\n",
    "3. Downloads Qwen2.5-1.5B-Instruct and runs each engine with `--measure_energy`\n",
    "4. Extrapolates measured J/req to the full 898-file controlled result bundle\n",
    "5. Saves results to Google Drive\n",
    "\n",
    "**Requirements:** Colab runtime with T4 GPU (Runtime → Change runtime type → T4 GPU)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "setup"},
   "source": ["## 1. Mount Google Drive and Unpack"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "mount"},
   "outputs": [],
   "source": [
    "from google.colab import drive\n",
    "import os, sys, tarfile, shutil, time\n",
    "\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "# Find the tgz in your Drive\n",
    "tgz_path = None\n",
    "for root, dirs, files in os.walk('/content/drive/MyDrive'):\n",
    "    for f in files:\n",
    "        if f == 't4_energy_transfer.tgz':\n",
    "            tgz_path = os.path.join(root, f)\n",
    "            break\n",
    "    if tgz_path:\n",
    "        break\n",
    "\n",
    "if tgz_path:\n",
    "    print(f'Found package: {tgz_path}')\n",
    "    # Extract\n",
    "    with tarfile.open(tgz_path, 'r:gz') as tar:\n",
    "        tar.extractall('/content/')\n",
    "    os.chdir('/content/t4_energy_transfer')\n",
    "    print(f'Extracted to /content/t4_energy_transfer')\n",
    "    print(f'Files: {len(os.listdir(\".\"))}')\n",
    "else:\n",
    "    print('ERROR: t4_energy_transfer.tgz not found in Google Drive.')\n",
    "    print('Upload it to your Drive root first, then re-run this cell.')\n",
    "    # Create directory anyway for manual upload\n",
    "    os.makedirs('/content/t4_energy_transfer', exist_ok=True)\n",
    "    os.chdir('/content/t4_energy_transfer')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "install"},
   "source": ["## 2. Install Dependencies (~3-5 min)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "install_deps"},
   "outputs": [],
   "source": [
    "print('Installing dependencies...')\n",
    "!pip install -U pip -q\n",
    "!pip install -e . -q\n",
    "!pip install pytest -q\n",
    "\n",
    "# Verify GPU\n",
    "import torch\n",
    "print(f'\\nGPU: {torch.cuda.get_device_name(0)}')\n",
    "print(f'Memory: {torch.cuda.get_device_properties(0).total_mem / 1024**3:.1f} GB')\n",
    "print(f'CUDA: {torch.version.cuda}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "smoke"},
   "source": ["## 3. Smoke Test (CPU, ~10 seconds)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "smoke_test"},
   "outputs": [],
   "source": [
    "print('Running smoke test...')\n",
    "!python experiments/run_benchmark.py --backend fake --workload synthetic \\\n",
    "  --n_requests 8 --include_experimental --disable_arrival_simulation \\\n",
    "  --output_dir /tmp/smoke\n",
    "print('Smoke test passed!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "energy"},
   "source": [
    "## 4. Run Energy Calibration Experiment\n",
    "\n",
    "This is the main experiment. Choose mode:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "choose_mode"},
   "outputs": [],
   "source": [
    "# Set to True for the quick run (~40 min), False for full run (~72 min)\n",
    "QUICK_MODE = False\n",
    "\n",
    "print(f'Mode: {\"QUICK (20 cells)\" if QUICK_MODE else \"FULL (36 cells)\"}')\n",
    "print(f'Estimated time: ~{\"40\" if QUICK_MODE else \"72\"} min')\n",
    "print()\n",
    "print('Make sure your Colab runtime is set to T4 GPU.')\n",
    "print('(Runtime -> Change runtime type -> Hardware accelerator: T4 GPU)')\n",
    "print()\n",
    "if QUICK_MODE:\n",
    "    print('Engines: no_cache, reactive, greedy, shadow_kv, shadow_kv_plus')\n",
    "else:\n",
    "    print('Engines: all 9 main engines + semantic ablations')\n",
    "print()\n",
    "confirm = input('Ready to start? (yes/no): ')\n",
    "if confirm.lower() != 'yes':\n",
    "    print('Cancelled.')\n",
    "    # We still create the output directory structure\n",
    "    os.makedirs('/content/t4_energy_transfer/results/t4_energy_calibration_full', exist_ok=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "run_experiment"},
   "outputs": [],
   "source": [
    "import subprocess, sys, time\n",
    "\n",
    "start_time = time.time()\n",
    "\n",
    "if QUICK_MODE:\n",
    "    cmd = [sys.executable, 'experiments/run_t4_energy_calibration.py', '--quick']\n",
    "else:\n",
    "    cmd = [sys.executable, 'experiments/run_t4_energy_calibration.py']\n",
    "\n",
    "print(f'Starting experiment: {\" \".join(cmd)}')\n",
    "print()\n",
    "\n",
    "result = subprocess.run(cmd, capture_output=True, text=True)\n",
    "print(result.stdout)\n",
    "if result.stderr:\n",
    "    print('STDERR:')\n",
    "    print(result.stderr[-2000:])\n",
    "\n",
    "elapsed = (time.time() - start_time) / 60\n",
    "print(f'\\nExperiment finished in {elapsed:.0f} minutes.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "calibrate"},
   "source": [
    "## 5. Calibrate Full Bundle\n",
    "\n",
    "Extrapolates the measured energy to all 898 controlled-result JSONs."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "run_calibrate"},
   "outputs": [],
   "source": [
    "print('Running calibration...')\n",
    "!python experiments/calibrate_energy_from_measurement.py\n",
    "print('\\nCalibration complete.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "results"},
   "source": ["## 6. Save Results to Google Drive"]
  ],
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "save_results"},
   "outputs": [],
   "source": [
    "import zipfile, glob\n",
    "\n",
    "# Determine the run label\n",
    "label = 'quick' if QUICK_MODE else 'full'\n",
    "results_dir = f'/content/t4_energy_transfer/results/t4_energy_calibration_{label}'\n",
    "calib_dir = '/content/t4_energy_transfer/results/t4_energy_calibration'\n",
    "\n",
    "# Verify results exist\n",
    "if os.path.exists(results_dir):\n",
    "    n_json = len(glob.glob(os.path.join(results_dir, '**', 'benchmark_*.json'), recursive=True))\n",
    "    print(f'Benchmark JSONs: {n_json}')\n",
    "else:\n",
    "    print('WARNING: No benchmark results found. The experiment may have failed.')\n",
    "\n",
    "if os.path.exists(calib_dir):\n",
    "    print(f'Calibration CSVs in: {calib_dir}')\n",
    "    for f in os.listdir(calib_dir):\n",
    "        print(f'  {f}')\n",
    "\n",
    "# Zip and save to Drive\n",
    "drive_out = '/content/drive/MyDrive/t4_energy_results'\n",
    "os.makedirs(drive_out, exist_ok=True)\n",
    "\n",
    "# Zip the calibration results\n",
    "zip_path = f'{drive_out}/t4_energy_calibration_{label}.zip'\n",
    "with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zf:\n",
    "    for root, dirs, files in os.walk('/content/t4_energy_transfer/results'):\n",
    "        for f in files:\n",
    "            file_path = os.path.join(root, f)\n",
    "            arcname = os.path.relpath(file_path, '/content/t4_energy_transfer/results')\n",
    "            zf.write(file_path, arcname)\n",
    "\n",
    "print(f'\\nResults saved to: {zip_path}')\n",
    "print(f'Size: {os.path.getsize(zip_path) / 1024 / 1024:.0f} MB')\n",
    "print()\n",
    "print('Download from Google Drive or copy to your local machine.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "summary"},
   "source": [
    "## 7. View Calibration Summary\n",
    "\n",
    "Preview the headline energy estimates."
   ]
